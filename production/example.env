# Plaid Credentials — replace with your real values from dashboard.plaid.com
PLAID_CLIENT_ID=your_client_id_here
PLAID_SECRET=your_production_secret_here
PLAID_ENV=production

# Do not enter manually, will propogate as you add banks
PLAID_ACCESS_TOKENS=[]

# Path inside the Docker container where Excel file is saved
EXCEL_FILE_PATH=/data/transactions.xlsx